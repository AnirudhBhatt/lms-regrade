  "info": {
    "_postman_id": "8b08fa11-46e3-4d7a-af0f-db6a978f6a9e",
    "name": "ReGrade LMS API Collection",
    "description": "Complete API collection for testing and verifying the ReGrade LMS Regrading Request workflow endpoints. Includes authentication, registration, assignment ownership, regrade requests, decisions, audit logs, and notifications.\n\n**MongoDB Connection:** mongodb://127.0.0.1:27017/regrade_lms\n**Backend Server:** http://localhost:5001\n**Frontend Server:** http://localhost:3456\n\n**Default Credentials:**\n- All seeded users: password123\n- u1: Anirudh Bhatt (student)\n- u2: Himanshu Kadyan (student)\n- u3: Yashasvi Dutt Sharma (student)\n- u4: Raygun Jose (instructor)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Reset and Seed Database",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:5001/api/reset",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "reset"
              ]
            },
            "description": "Clears all collections in the MongoDB database and re-seeds them with initial sample data (4 users, 3 assignments, 9 grades, 5 requests, 3 decisions, 13 audit logs, and 5 notifications). Use this before running test flows."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "description": "User registration and login endpoints. Supports both password-based login and Google OAuth bypass.",
      "item": [
        {
          "name": "Register New Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"u10\",\n  \"name\": \"New Student\",\n  \"email\": \"newstudent@upes.edu\",\n  \"password\": \"mypassword123\",\n  \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/users",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Registers a new student in the LMS. When a student is registered, the system automatically generates default Grade records (70% of maxScore) for ALL existing assignments, allowing them to immediately view grades and submit regrade requests.\n\n**Validation:**\n- ID and Email must be unique (returns 400 if duplicate)\n- All fields are required\n\n**Auto-population:** Creates grade entries for every assignment in the database."
          },
          "response": []
        },
        {
          "name": "Register New Instructor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"inst2\",\n  \"name\": \"New Instructor\",\n  \"email\": \"newinstructor@upes.edu\",\n  \"password\": \"securepass456\",\n  \"role\": \"instructor\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/users",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Registers a new instructor in the LMS. Instructors can create assignments, review regrade requests for their own assignments, and submit decisions.\n\n**Note:** Unlike students, no grades are auto-populated for instructors."
          },
          "response": []
        },
        {
          "name": "Login with Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginId\": \"u1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/users/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Authenticates a user with their User ID (or Email) and password. Returns the full user object on success.\n\n**loginId** accepts either the user's unique ID (e.g. 'u1') or their email (e.g. 'anirudh@upes.edu').\n\n**Default password for all seeded users:** password123\n\n**Returns:**\n- 200: User object (id, name, role, email, avatar)\n- 401: Invalid user ID/Email or Incorrect password"
          },
          "response": []
        },
