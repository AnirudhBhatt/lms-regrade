              "mode": "raw",
              "raw": "{\n  \"requestId\": \"rr4\",\n  \"instructorId\": \"u4\",\n  \"decision\": \"Accepted\",\n  \"justification\": \"After reviewing the student's BST implementation, the null-pointer edge case is handled correctly on line 28. The autograder test configuration issue has been confirmed. Grade revised accordingly.\",\n  \"revisedGrade\": 45\n}"
            },
