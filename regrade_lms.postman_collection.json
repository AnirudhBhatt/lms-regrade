        {
          "name": "Submit Regrade Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"u1\",\n  \"assignmentId\": \"a2\",\n  \"originalGrade\": 118,\n  \"claimedGrade\": 125,\n  \"reason\": \"grading_error\",\n  \"reasonDetail\": \"Task 3 rubric says 10 points for correct time complexity analysis, but I got 3 points despite giving the correct O(E log V) derivation.\",\n  \"evidenceType\": \"text\",\n  \"evidence\": \"On line 42 of my project code, the Dijkstra implementation uses a min-priority queue which guarantees O(E log V) complexity.\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/requests",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "requests"
              ]
            },
            "description": "Submits a new regrade request. Employs a guard check to prevent creating duplicate active requests for the same assignment.\n\n**Duplicate Guard:** If a non-Closed request already exists for this student + assignment combo, returns 400."
          },
          "response": []
        },
        {
          "name": "Update Request Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Under Review\",\n  \"actorId\": \"u4\",\n  \"actorRole\": \"instructor\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/requests/:id/status",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "requests",
                ":id",
                "status"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "rr4",
                  "description": "The unique ID of the request to update"
                }
              ]
            },
            "description": "Updates the status of an existing regrade request (e.g. to 'Under Review') and logs a workflow transition in the audit log."
          },
          "response": []
        },
        {
          "name": "Reopen Request (Student)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"u2\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/requests/:id/reopen",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5001",
              "path": [
                "api",
                "requests",
                ":id",
                "reopen"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "rr2",
                  "description": "The unique ID of the rejected request to reopen"
                }
              ]
            },
            "description": "Reopens a previously Rejected request. Enforces a strict 1-time reopen limit per request and logs the reopening in the audit log.\n\n**Guards:**\n- Only the owning student can reopen\n- Only Rejected requests can be reopened\n- Maximum 1 reopen per request"
          },
          "response": []
        }
      ]
